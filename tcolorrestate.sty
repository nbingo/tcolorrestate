% tcolorrestate.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tcolorrestate}[2026/05/28 Colored/restatable theorem boxes with configurable colors]

% ------------------------------------------------------------
% Package options
% ------------------------------------------------------------
%
% Basic usage:
%   \usepackage{tcolorrestate}
%
% Plain, unboxed theorems:
%   \usepackage[plain]{tcolorrestate}
%
% Custom base colors:
%   \usepackage[
%     theoremcolor=MidnightBlue,
%     definitioncolor=BrickRed,
%     lemmacolor=RoyalBlue,
%     remarkcolor=Plum,
%     examplecolor=ForestGreen,
%     warningcolor=Orange,
%     conjecturecolor=Sepia
%   ]{tcolorrestate}
%
% Fully custom background/frame colors:
%   \usepackage[
%     theoremback=blue!3,
%     theoremframe=blue!60!black,
%     definitionback=red!3,
%     definitionframe=red!60!black
%   ]{tcolorrestate}

\RequirePackage{kvoptions}

\SetupKeyvalOptions{
  family=tcolorrestate,
  prefix=tcolorrestate@
}

\DeclareBoolOption[false]{plain}

% Base color options.  The default background/frame colors are derived as
% <base>!5 and <base>!70!black, respectively, unless explicitly overridden
% by the corresponding *back or *frame option below.
\DeclareStringOption[Cerulean]{theoremcolor}
\DeclareStringOption[red]{definitioncolor}
\DeclareStringOption[Cerulean]{lemmacolor}
\DeclareStringOption[Plum]{remarkcolor}
\DeclareStringOption[ForestGreen]{examplecolor}
\DeclareStringOption[WarnColor]{warningcolor}
\DeclareStringOption[Sepia]{conjecturecolor}

% These default to the lemma color unless specified separately.
\DeclareStringOption[]{factcolor}
\DeclareStringOption[]{claimcolor}
\DeclareStringOption[]{corollarycolor}
\DeclareStringOption[]{propositioncolor}

% Optional direct background-color overrides.
\DeclareStringOption[]{theoremback}
\DeclareStringOption[]{definitionback}
\DeclareStringOption[]{lemmaback}
\DeclareStringOption[]{remarkback}
\DeclareStringOption[]{exampleback}
\DeclareStringOption[]{warningback}
\DeclareStringOption[]{conjectureback}
\DeclareStringOption[]{factback}
\DeclareStringOption[]{claimback}
\DeclareStringOption[]{corollaryback}
\DeclareStringOption[]{propositionback}

% Optional direct frame-color overrides.
\DeclareStringOption[]{theoremframe}
\DeclareStringOption[]{definitionframe}
\DeclareStringOption[]{lemmaframe}
\DeclareStringOption[]{remarkframe}
\DeclareStringOption[]{exampleframe}
\DeclareStringOption[]{warningframe}
\DeclareStringOption[]{conjectureframe}
\DeclareStringOption[]{factframe}
\DeclareStringOption[]{claimframe}
\DeclareStringOption[]{corollaryframe}
\DeclareStringOption[]{propositionframe}

\ProcessKeyvalOptions*

% ------------------------------------------------------------
% Required packages
% ------------------------------------------------------------

\RequirePackage[dvipsnames]{xcolor}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{theorems,breakable,skins}
\RequirePackage{amsthm}
\RequirePackage{thmtools}
\RequirePackage{thm-restate}

% ------------------------------------------------------------
% Colors and tcolorbox styles
% ------------------------------------------------------------

\definecolor{WarnColor}{HTML}{FFCC00}

% Fill in inherited colors and derived background/frame colors.
\makeatletter

% Environments that used to share lem-style inherit the lemma base color
% unless the user explicitly supplied a separate base color.
\ifx\tcolorrestate@factcolor\@empty
  \let\tcolorrestate@factcolor\tcolorrestate@lemmacolor
\fi
\ifx\tcolorrestate@claimcolor\@empty
  \let\tcolorrestate@claimcolor\tcolorrestate@lemmacolor
\fi
\ifx\tcolorrestate@corollarycolor\@empty
  \let\tcolorrestate@corollarycolor\tcolorrestate@lemmacolor
\fi
\ifx\tcolorrestate@propositioncolor\@empty
  \let\tcolorrestate@propositioncolor\tcolorrestate@lemmacolor
\fi

% If no explicit background/frame is supplied, derive it from the base color.
\ifx\tcolorrestate@theoremback\@empty
  \edef\tcolorrestate@theoremback{\tcolorrestate@theoremcolor!5}%
\fi
\ifx\tcolorrestate@theoremframe\@empty
  \edef\tcolorrestate@theoremframe{\tcolorrestate@theoremcolor!70!black}%
\fi

\ifx\tcolorrestate@definitionback\@empty
  \edef\tcolorrestate@definitionback{\tcolorrestate@definitioncolor!5}%
\fi
\ifx\tcolorrestate@definitionframe\@empty
  \edef\tcolorrestate@definitionframe{\tcolorrestate@definitioncolor!70!black}%
\fi

\ifx\tcolorrestate@lemmaback\@empty
  \edef\tcolorrestate@lemmaback{\tcolorrestate@lemmacolor!5}%
\fi
\ifx\tcolorrestate@lemmaframe\@empty
  \edef\tcolorrestate@lemmaframe{\tcolorrestate@lemmacolor!70!black}%
\fi

\ifx\tcolorrestate@remarkback\@empty
  \edef\tcolorrestate@remarkback{\tcolorrestate@remarkcolor!5}%
\fi
\ifx\tcolorrestate@remarkframe\@empty
  \edef\tcolorrestate@remarkframe{\tcolorrestate@remarkcolor!70!black}%
\fi

\ifx\tcolorrestate@exampleback\@empty
  \edef\tcolorrestate@exampleback{\tcolorrestate@examplecolor!5}%
\fi
\ifx\tcolorrestate@exampleframe\@empty
  \edef\tcolorrestate@exampleframe{\tcolorrestate@examplecolor!70!black}%
\fi

\ifx\tcolorrestate@warningback\@empty
  \edef\tcolorrestate@warningback{\tcolorrestate@warningcolor!25}%
\fi
\ifx\tcolorrestate@warningframe\@empty
  \edef\tcolorrestate@warningframe{\tcolorrestate@warningcolor!70!black}%
\fi

\ifx\tcolorrestate@conjectureback\@empty
  \edef\tcolorrestate@conjectureback{\tcolorrestate@conjecturecolor!5}%
\fi
\ifx\tcolorrestate@conjectureframe\@empty
  \edef\tcolorrestate@conjectureframe{\tcolorrestate@conjecturecolor!70!black}%
\fi

\ifx\tcolorrestate@factback\@empty
  \edef\tcolorrestate@factback{\tcolorrestate@factcolor!5}%
\fi
\ifx\tcolorrestate@factframe\@empty
  \edef\tcolorrestate@factframe{\tcolorrestate@factcolor!70!black}%
\fi

\ifx\tcolorrestate@claimback\@empty
  \edef\tcolorrestate@claimback{\tcolorrestate@claimcolor!5}%
\fi
\ifx\tcolorrestate@claimframe\@empty
  \edef\tcolorrestate@claimframe{\tcolorrestate@claimcolor!70!black}%
\fi

\ifx\tcolorrestate@corollaryback\@empty
  \edef\tcolorrestate@corollaryback{\tcolorrestate@corollarycolor!5}%
\fi
\ifx\tcolorrestate@corollaryframe\@empty
  \edef\tcolorrestate@corollaryframe{\tcolorrestate@corollarycolor!70!black}%
\fi

\ifx\tcolorrestate@propositionback\@empty
  \edef\tcolorrestate@propositionback{\tcolorrestate@propositioncolor!5}%
\fi
\ifx\tcolorrestate@propositionframe\@empty
  \edef\tcolorrestate@propositionframe{\tcolorrestate@propositioncolor!70!black}%
\fi

% Freeze the selected color expressions into ordinary xcolor color names.
% This avoids having internal macros containing @ evaluated later, when @ may
% no longer be a letter.
\colorlet{tcolorrestateTheoremBack}{\tcolorrestate@theoremback}
\colorlet{tcolorrestateTheoremFrame}{\tcolorrestate@theoremframe}
\colorlet{tcolorrestateDefinitionBack}{\tcolorrestate@definitionback}
\colorlet{tcolorrestateDefinitionFrame}{\tcolorrestate@definitionframe}
\colorlet{tcolorrestateLemmaBack}{\tcolorrestate@lemmaback}
\colorlet{tcolorrestateLemmaFrame}{\tcolorrestate@lemmaframe}
\colorlet{tcolorrestateRemarkBack}{\tcolorrestate@remarkback}
\colorlet{tcolorrestateRemarkFrame}{\tcolorrestate@remarkframe}
\colorlet{tcolorrestateExampleBack}{\tcolorrestate@exampleback}
\colorlet{tcolorrestateExampleFrame}{\tcolorrestate@exampleframe}
\colorlet{tcolorrestateWarningBack}{\tcolorrestate@warningback}
\colorlet{tcolorrestateWarningFrame}{\tcolorrestate@warningframe}
\colorlet{tcolorrestateFactBack}{\tcolorrestate@factback}
\colorlet{tcolorrestateFactFrame}{\tcolorrestate@factframe}
\colorlet{tcolorrestateClaimBack}{\tcolorrestate@claimback}
\colorlet{tcolorrestateClaimFrame}{\tcolorrestate@claimframe}
\colorlet{tcolorrestateCorollaryBack}{\tcolorrestate@corollaryback}
\colorlet{tcolorrestateCorollaryFrame}{\tcolorrestate@corollaryframe}
\colorlet{tcolorrestatePropositionBack}{\tcolorrestate@propositionback}
\colorlet{tcolorrestatePropositionFrame}{\tcolorrestate@propositionframe}
\colorlet{tcolorrestateConjectureBack}{\tcolorrestate@conjectureback}
\colorlet{tcolorrestateConjectureFrame}{\tcolorrestate@conjectureframe}


\tcbset{
  thm-base/.style={
    enhanced,
    breakable,
    boxrule=0.8pt,
    arc=2mm,
    left=1ex,
    right=1ex,
    top=0.8ex,
    bottom=0.8ex,
    colback=tcolorrestateTheoremBack,
    colframe=tcolorrestateTheoremFrame,
    opacityback=1,
  },
  def-style/.style={
    thm-base,
    colback=tcolorrestateDefinitionBack,
    colframe=tcolorrestateDefinitionFrame,
  },
  lem-style/.style={
    thm-base,
    colback=tcolorrestateLemmaBack,
    colframe=tcolorrestateLemmaFrame,
  },
  rmk-style/.style={
    thm-base,
    colback=tcolorrestateRemarkBack,
    colframe=tcolorrestateRemarkFrame,
  },
  ex-style/.style={
    thm-base,
    colback=tcolorrestateExampleBack,
    colframe=tcolorrestateExampleFrame,
  },
  warn-style/.style={
    thm-base,
    colback=tcolorrestateWarningBack,
    colframe=tcolorrestateWarningFrame,
  },
  fact-style/.style={
    thm-base,
    colback=tcolorrestateFactBack,
    colframe=tcolorrestateFactFrame,
  },
  claim-style/.style={
    thm-base,
    colback=tcolorrestateClaimBack,
    colframe=tcolorrestateClaimFrame,
  },
  cor-style/.style={
    thm-base,
    colback=tcolorrestateCorollaryBack,
    colframe=tcolorrestateCorollaryFrame,
  },
  prop-style/.style={
    thm-base,
    colback=tcolorrestatePropositionBack,
    colframe=tcolorrestatePropositionFrame,
  },
  conj-style/.style={
    thm-base,
    colback=tcolorrestateConjectureBack,
    colframe=tcolorrestateConjectureFrame,
  },
}

% ------------------------------------------------------------
% Theorem style
% ------------------------------------------------------------

\declaretheoremstyle[
  headfont=\bfseries,
  bodyfont=\normalfont,
  spaceabove=6pt,
  spacebelow=6pt,
  headpunct={.},
  postheadspace=0.5em
]{thmplain}

% ------------------------------------------------------------
% Theorem environments
% ------------------------------------------------------------

\declaretheorem[
  style=thmplain,
  numberwithin=section
]{theorem}

\declaretheorem[
  style=thmplain,
  name=Definition,
  sibling=theorem
]{definition}

\declaretheorem[
  style=thmplain,
  name=Lemma,
  sibling=theorem
]{lemma}

\declaretheorem[
  style=thmplain,
  name=Remark,
  sibling=theorem
]{remark}

\declaretheorem[
  style=thmplain,
  name=Example,
  sibling=theorem
]{example}

\declaretheorem[
  style=thmplain,
  name=Fact,
  sibling=theorem
]{fact}

\declaretheorem[
  style=thmplain,
  name=Warning,
  sibling=theorem
]{warning}

\declaretheorem[
  style=thmplain,
  name=Claim,
  sibling=theorem
]{claim}

\declaretheorem[
  style=thmplain,
  name=Corollary,
  sibling=theorem
]{corollary}

\declaretheorem[
  style=thmplain,
  name=Proposition,
  sibling=theorem
]{proposition}

\declaretheorem[
  style=thmplain,
  name=Conjecture,
  sibling=theorem
]{conjecture}

% ------------------------------------------------------------
% Wrap theorem environments in color boxes,
% unless the package is loaded with [plain].
%
% Important:
% We use thmtools hooks rather than \tcolorboxenvironment,
% so that restatable theorems are boxed too.
% ------------------------------------------------------------

\iftcolorrestate@plain
  % Do nothing: theorem environments remain plain.
\else
  \addtotheorempreheadhook[theorem]{%
    \begin{tcolorbox}[thm-base]%
  }%
  \addtotheorempostfoothook[theorem]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[definition]{%
    \begin{tcolorbox}[def-style]%
  }%
  \addtotheorempostfoothook[definition]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[lemma]{%
    \begin{tcolorbox}[lem-style]%
  }%
  \addtotheorempostfoothook[lemma]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[remark]{%
    \begin{tcolorbox}[rmk-style]%
  }%
  \addtotheorempostfoothook[remark]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[example]{%
    \begin{tcolorbox}[ex-style]%
  }%
  \addtotheorempostfoothook[example]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[fact]{%
    \begin{tcolorbox}[fact-style]%
  }%
  \addtotheorempostfoothook[fact]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[warning]{%
    \begin{tcolorbox}[warn-style]%
  }%
  \addtotheorempostfoothook[warning]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[claim]{%
    \begin{tcolorbox}[claim-style]%
  }%
  \addtotheorempostfoothook[claim]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[corollary]{%
    \begin{tcolorbox}[cor-style]%
  }%
  \addtotheorempostfoothook[corollary]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[proposition]{%
    \begin{tcolorbox}[prop-style]%
  }%
  \addtotheorempostfoothook[proposition]{%
    \end{tcolorbox}%
  }%

  \addtotheorempreheadhook[conjecture]{%
    \begin{tcolorbox}[conj-style]%
  }%
  \addtotheorempostfoothook[conjecture]{%
    \end{tcolorbox}%
  }%
\fi

% ------------------------------------------------------------
% cleveref names
% ------------------------------------------------------------

\makeatletter

\newcommand{\tcolorrestate@setcrefnames}{%
  \crefname{theorem}{theorem}{theorems}%
  \Crefname{theorem}{Theorem}{Theorems}%

  \crefname{definition}{definition}{definitions}%
  \Crefname{definition}{Definition}{Definitions}%

  \crefname{lemma}{lemma}{lemmas}%
  \Crefname{lemma}{Lemma}{Lemmas}%

  \crefname{remark}{remark}{remarks}%
  \Crefname{remark}{Remark}{Remarks}%

  \crefname{example}{example}{examples}%
  \Crefname{example}{Example}{Examples}%

  \crefname{fact}{fact}{facts}%
  \Crefname{fact}{Fact}{Facts}%

  \crefname{warning}{warning}{warnings}%
  \Crefname{warning}{Warning}{Warnings}%

  \crefname{claim}{claim}{claims}%
  \Crefname{claim}{Claim}{Claims}%

  \crefname{corollary}{corollary}{corollaries}%
  \Crefname{corollary}{Corollary}{Corollaries}%

  \crefname{proposition}{proposition}{propositions}%
  \Crefname{proposition}{Proposition}{Propositions}%

  \crefname{conjecture}{conjecture}{conjectures}%
  \Crefname{conjecture}{Conjecture}{Conjectures}%
}

\@ifpackageloaded{cleveref}{%
  \tcolorrestate@setcrefnames
}{%
  \AddToHook{package/cleveref/after}{\tcolorrestate@setcrefnames}%
}

\makeatother
